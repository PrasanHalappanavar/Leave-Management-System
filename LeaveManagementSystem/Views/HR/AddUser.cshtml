@{
    ViewData["Title"] = "Add User";
    Layout = "~/Views/Shared/_HRLayout.cshtml";
}

<center><div class="page-title">Add Employee / Manager</div></center>

<div class="form-box">
    <div class="alert alert-success" id="successMsg"></div>
    <div class="alert alert-error" id="errorMsg"></div>

    <div class="form-group">
        <label>Full Name</label>
        <input type="text" id="fullName" placeholder="Enter full name"  required/>
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" id="email" placeholder="Enter email" required />
    </div>

    <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" placeholder="Enter password" required />
    </div>

    <div class="form-group">
        <label>Role</label>
        <select id="role" required>
            <option value="">Select role</option>
            <option value="1">Employee</option>
            <option value="2">Manager</option>
        </select>
    </div>

    <div class="form-group">
        <label>Department</label>
        <select id="departmentId" required>
            <option value="">Select department</option>
            <option value="1">IT</option>
            <option value="2">HR</option>
        </select>
    </div>

    <button class="btn btn-primary" id="btnAdd">Add User</button>
</div>

@section Scripts {
    <script>
        $('#btnAdd').on('click', function () {
            var fullName     = $('#fullName').val().trim();
            var email        = $('#email').val().trim();
            var password     = $('#password').val().trim();
            var role         = $('#role').val();
            var departmentId = $('#departmentId').val();

            if (!fullName || !email || !password || !role || !departmentId) {
                showError('Please fill all fields');
                return;
            }

            $('#btnAdd').prop('disabled', true).text('Adding...');

            $.ajax({
                url: '/api/hr/adduser',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    fullName: fullName,
                    email: email,
                    password: password,
                    role: parseInt(role),
                    departmentId: parseInt(departmentId)
                }),
                success: function (res) {
                    if (res.success) {
                        showSuccess(res.message);
                        $('#fullName').val('');
                        $('#email').val('');
                        $('#password').val('');
                        $('#role').val('');
                        $('#departmentId').val('');
                    } else {
                        showError(res.message);
                    }
                    $('#btnAdd').prop('disabled', false).text('Add User');
                },
                error: function () {
                    showError('Something went wrong. Try again.');
                    $('#btnAdd').prop('disabled', false).text('Add User');
                }
            });
        });

        function showSuccess(msg) {
            $('#errorMsg').hide();
            $('#successMsg').text(msg).fadeIn();
        }

        function showError(msg) {
            $('#successMsg').hide();
            $('#errorMsg').text(msg).fadeIn();
        }
    </script>
}