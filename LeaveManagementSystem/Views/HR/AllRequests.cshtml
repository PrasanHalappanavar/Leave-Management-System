@{
    ViewData["Title"] = "All Requests";
    Layout = "~/Views/Shared/_HRLayout.cshtml";
}

<div class="page-title">All Leave Requests</div>

<div class="alert alert-error" id="errorMsg"></div>

<div class="table-box">
    <div class="search-bar">
        <input type="text" id="searchInput"
               placeholder="Search by employee or manager..." />
        <select id="statusFilter">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
            <option value="Expired">Expired</option>
        </select>
        <button class="btn-clear" id="btnClear">Clear</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Employee</th>
                <th>Manager</th>
                <th>Leave Type</th>
                <th>From</th>
                <th>To</th>
                <th>Days</th>
                <th>Status</th>
                <th>Applied On</th>
                <th>Remarks</th>
            </tr>
        </thead>
        <tbody id="requestsTable">
            <tr>
                <td colspan="9" style="text-align:center;color:#888;">Loading...</td>
            </tr>
        </tbody>
    </table>

    <div class="pagination">
        <span class="pagination-info" id="pageInfo"></span>
        <div class="pagination-buttons" id="pageButtons"></div>
    </div>
</div>

@section Scripts {
    <script>
        var allRequests = [];

        $.ajax({
            url: '/api/hr/allrequests',
            type: 'GET',
            success: function (data) {
                allRequests = data;
                renderPaginated(data);
            },
            error: function () {
                showToast('Failed to load requests.', 'error');
            }
        });

        $('#searchInput').on('keyup', function () {
            applyFilters();
        });

        $('#statusFilter').on('change', function () {
            applyFilters();
        });

        $('#btnClear').on('click', function () {
            $('#searchInput').val('');
            $('#statusFilter').val('');
            renderPaginated(allRequests);
        });

        function applyFilters() {
            var keyword = $('#searchInput').val().toLowerCase().trim();
            var status  = $('#statusFilter').val();

            var filtered = $.grep(allRequests, function (r) {
                var matchName =
                    !keyword ||
                    r.employeeName.toLowerCase().indexOf(keyword) >= 0 ||
                    r.managerName.toLowerCase().indexOf(keyword)  >= 0;
                var matchStatus = !status || r.status === status;
                return matchName && matchStatus;
            });

            renderPaginated(filtered);
        }

        function renderPaginated(data) {
            paginate(data, 'requestsTable', 'pageInfo', 'pageButtons', 10,
                function (r) {
                    return '<tr>' +
                        '<td>' + r.employeeName  + '</td>' +
                        '<td>' + r.managerName   + '</td>' +
                        '<td>' + r.leaveTypeName + '</td>' +
                        '<td>' + formatDate(r.fromDate)  + '</td>' +
                        '<td>' + formatDate(r.toDate)    + '</td>' +
                        '<td>' + r.totalDays     + '</td>' +
                        '<td><span class="badge badge-' + r.status + '">' +
                            r.status + '</span></td>' +
                        '<td>' + formatDate(r.appliedOn) + '</td>' +
                        '<td>' + (r.remarksFromManager || '—') + '</td>' +
                        '</tr>';
                }
            );
        }

        function formatDate(dateStr) {
            if (!dateStr) return '—';
            var d = new Date(dateStr);
            return d.getDate().toString().padStart(2, '0') + '/' +
                   (d.getMonth() + 1).toString().padStart(2, '0') + '/' +
                   d.getFullYear();
        }
    </script>
}