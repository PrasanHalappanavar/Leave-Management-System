@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — LMS</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="login-wrapper">
        <div class="login-box">
            <div class="login-title">Leave Management</div>
            <div class="login-sub">Sign in to your account</div>

            <div class="alert alert-error" id="alertMsg"></div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" id="password" placeholder="Enter your password" />
            </div>

            <button class="btn btn-primary" style="width:100%" id="btnLogin">Sign In</button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $('#btnLogin').on('click', function () {
            var email    = $('#email').val().trim();
            var password = $('#password').val().trim();

            if (!email || !password) {
                showAlert('Please enter email and password');
                return;
            }

            $('#btnLogin').prop('disabled', true).text('Signing in...');

            $.ajax({
                url: '/api/auth/login',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ email: email, password: password }),
                success: function (res) {
                    if (res.success) {
                        window.location.href = res.redirectUrl;
                    } else {
                        showAlert(res.message);
                        $('#btnLogin').prop('disabled', false).text('Sign In');
                    }
                },
                error: function () {
                    showAlert('Something went wrong. Try again.');
                    $('#btnLogin').prop('disabled', false).text('Sign In');
                }
            });
        });


        function showAlert(msg) {
            $('#alertMsg').text(msg).fadeIn();
        }
    </script>

</body>
</html>