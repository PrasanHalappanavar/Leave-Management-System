@{
    ViewData["Title"] = "My Requests";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-title">My Leave Requests</div>

<div class="table-box">
    <table>
        <thead>
            <tr>
                <th>Leave Type</th>
                <th>From</th>
                <th>To</th>
                <th>Days</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Remarks</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="requestsTable">
            <tr>
                <td colspan="8"
                    style="text-align:center;color:#888;">
                    Loading...
                </td>
            </tr>
        </tbody>
    </table>
    <div class="pagination">
        <span class="pagination-info" id="pageInfo"></span>
        <div class="pagination-buttons" id="pageButtons"></div>
    </div>
</div>

<div class="modal-overlay" id="cancelModal">
    <div class="modal-box">
        <div class="modal-title">Cancel Leave Request</div>
        <p style="font-size:14px;color:#555;margin-bottom:16px;">
            Are you sure you want to cancel this leave request?
            This action cannot be undone.
        </p>
        <div class="modal-actions">
            <button class="btn btn-danger" id="btnConfirmCancel">
                Yes, Cancel It
            </button>
            <button class="btn"
                    style="background:#eee;color:#333;"
                    id="btnCloseCancel">
                No, Keep It
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allRequests    = [];
        var cancelRequestId = null;

        loadRequests();

        function loadRequests() {
            $.ajax({
                url: '/api/employee/myrequests',
                type: 'GET',
                success: function (data) {
                    allRequests = data;
                    renderPaginated(data);
                },
                error: function () {
                    showToast('Failed to load requests.', 'error');
                }
            });
        }

        function renderPaginated(data) {
            paginate(data, 'requestsTable', 'pageInfo', 'pageButtons', 10,
                function (r) {
                    var action = r.status === 'Pending'
                        ? '<button class="btn btn-danger" ' +
                          'style="font-size:12px;padding:5px 12px" ' +
                          'onclick="openCancelModal(' + r.requestId + ')">Cancel</button>'
                        : '—';

                    return '<tr id="row-' + r.requestId + '">' +
                        '<td>' + r.leaveTypeName + '</td>' +
                        '<td>' + formatDate(r.fromDate) + '</td>' +
                        '<td>' + formatDate(r.toDate)   + '</td>' +
                        '<td>' + r.totalDays + '</td>' +
                        '<td>' + r.reason    + '</td>' +
                        '<td class="status-cell-' + r.requestId + '">' +
                            '<span class="badge badge-' + r.status + '">' +
                                r.status +
                            '</span>' +
                        '</td>' +
                        '<td>' + (r.remarksFromManager || '—') + '</td>' +
                        '<td class="action-cell-' + r.requestId + '">' +
                            action +
                        '</td>' +
                        '</tr>';
                }
            );
        }

        function openCancelModal(requestId) {
            cancelRequestId = requestId;
            $('#cancelModal').addClass('show');
        }

        $('#btnCloseCancel').on('click', function () {
            $('#cancelModal').removeClass('show');
            cancelRequestId = null;
        });

        $('#btnConfirmCancel').on('click', function () {
            if (!cancelRequestId) return;

            $('#btnConfirmCancel').prop('disabled', true).text('Cancelling...');

            $.ajax({
                url: '/api/employee/cancel/' + cancelRequestId,
                type: 'POST',
                success: function (res) {
                    $('#cancelModal').removeClass('show');

                    if (res.success) {
                        $('.status-cell-' + cancelRequestId).html(
                            '<span class="badge badge-Cancelled">Cancelled</span>'
                        );

                        $('.action-cell-' + cancelRequestId).html('—');

                        $.each(allRequests, function (i, r) {
                            if (r.requestId === cancelRequestId) {
                                r.status = 'Cancelled';
                            }
                        });

                        showToast(res.message, 'success');
                    } else {
                        showToast(res.message, 'error');
                    }

                    cancelRequestId = null;
                    $('#btnConfirmCancel').prop('disabled', false)
                                         .text('Yes, Cancel It');
                },
                error: function () {
                    showToast('Something went wrong.', 'error');
                    $('#btnConfirmCancel').prop('disabled', false)
                                         .text('Yes, Cancel It');
                }
            });
        });

        function formatDate(dateStr) {
            if (!dateStr) return '—';
            var d = new Date(dateStr);
            return d.getDate().toString().padStart(2, '0') + '/' +
                   (d.getMonth() + 1).toString().padStart(2, '0') + '/' +
                   d.getFullYear();
        }
    </script>
}